
import React, { useState } from 'react';
import { Server } from '../types';
import { Search, X, Zap, Globe2 } from 'lucide-react';

interface Props {
  servers: Server[];
  selectedId: string;
  onSelect: (server: Server) => void;
}

export const ServerList: React.FC<Props> = ({ servers, selectedId, onSelect }) => {
  const [searchTerm, setSearchTerm] = useState('');
  const [activeRegion, setActiveRegion] = useState<string>('All');

  const filtered = servers.filter(s => {
    const matchesSearch = s.name.toLowerCase().includes(searchTerm.toLowerCase()) || 
                          s.country.toLowerCase().includes(searchTerm.toLowerCase());
    const matchesRegion = activeRegion === 'All' || s.region === activeRegion;
    return matchesSearch && matchesRegion;
  });

  const regions = ['All', 'Americas', 'Europe', 'Asia'];

  return (
    <div className="max-w-4xl mx-auto space-y-6 pb-20">
      <div className="flex flex-col md:flex-row md:items-center justify-between gap-4">
        <div>
          <h2 className="text-2xl font-bold">Global Network</h2>
          <p className="text-gray-400 text-sm">Choose from 6,500+ ultra-fast servers</p>
        </div>
        
        <div className="flex items-center gap-2 overflow-x-auto pb-2 md:pb-0 scrollbar-hide">
          {regions.map(r => (
            <button
              key={r}
              onClick={() => setActiveRegion(r)}
              className={`px-4 py-2 rounded-full text-xs font-semibold whitespace-nowrap transition-all ${
                activeRegion === r ? 'bg-indigo-600 text-white' : 'bg-white/5 text-gray-400 hover:bg-white/10'
              }`}
            >
              {r}
            </button>
          ))}
        </div>
      </div>

      {/* Search Input Container */}
      <div className="relative group">
        <Search className="absolute left-4 top-1/2 -translate-y-1/2 w-5 h-5 text-gray-500 group-focus-within:text-indigo-500 transition-colors" />
        <input 
          type="text"
          placeholder="Search by city or country..."
          className="w-full bg-[#111114] border border-white/5 rounded-2xl py-4 pl-12 pr-12 focus:outline-none focus:ring-2 focus:ring-indigo-500/50 transition-all text-white"
          value={searchTerm}
          onChange={(e) => setSearchTerm(e.target.value)}
        />
        {searchTerm && (
          <button 
            onClick={() => setSearchTerm('')}
            className="absolute right-4 top-1/2 -translate-y-1/2 p-1 hover:bg-white/10 rounded-full text-gray-500 hover:text-white transition-all"
          >
            <X className="w-4 h-4" />
          </button>
        )}
      </div>

      {/* Servers Grid or Empty State */}
      {filtered.length > 0 ? (
        <div className="grid grid-cols-1 md:grid-cols-2 gap-4">
          {filtered.map(server => (
            <button
              key={server.id}
              onClick={() => onSelect(server)}
              className={`flex items-center gap-4 p-5 rounded-3xl border transition-all text-left group ${
                selectedId === server.id 
                  ? 'bg-indigo-600/10 border-indigo-500/50 ring-1 ring-indigo-500/20' 
                  : 'bg-[#111114] border-white/5 hover:border-white/20 hover:bg-white/5'
              }`}
            >
              <span className="text-3xl filter grayscale group-hover:grayscale-0 transition-all duration-300">
                {server.flag}
              </span>
              <div className="flex-1">
                <h4 className={`font-bold transition-colors ${selectedId === server.id ? 'text-indigo-400' : 'text-gray-100'}`}>
                  {server.name}
                </h4>
                <p className="text-xs text-gray-400">{server.country}</p>
              </div>
              <div className="flex flex-col items-end gap-1">
                <div className="flex items-center gap-1 text-xs font-mono text-indigo-400">
                  <Zap className="w-3 h-3" /> {server.latency}ms
                </div>
                <div className="w-16 h-1.5 bg-white/5 rounded-full overflow-hidden">
                  <div 
                    className={`h-full rounded-full transition-all duration-500 ${server.load > 80 ? 'bg-red-500' : server.load > 50 ? 'bg-yellow-500' : 'bg-green-500'}`} 
                    style={{ width: `${server.load}%` }}
                  />
                </div>
                <span className="text-[10px] text-gray-500 uppercase tracking-tighter">Load: {server.load}%</span>
              </div>
            </button>
          ))}
        </div>
      ) : (
        <div className="flex flex-col items-center justify-center py-20 bg-[#111114] border border-dashed border-white/10 rounded-3xl text-center">
          <div className="p-4 bg-white/5 rounded-full mb-4">
            <Globe2 className="w-10 h-10 text-gray-600" />
          </div>
          <h3 className="text-lg font-bold text-gray-300">No servers found</h3>
          <p className="text-sm text-gray-500 max-w-xs mt-1 px-4">
            We couldn't find any servers matching "{searchTerm}" in {activeRegion === 'All' ? 'any region' : activeRegion}.
          </p>
          <button 
            onClick={() => { setSearchTerm(''); setActiveRegion('All'); }}
            className="mt-6 text-sm font-semibold text-indigo-400 hover:text-indigo-300 transition-colors"
          >
            Clear all filters
          </button>
        </div>
      )}
    </div>
  );
};
